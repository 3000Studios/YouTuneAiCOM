{
  "name": "youtuneai-wordpress-site",
  "version": "1.0.0",
  "description": "YouTuneAI WordPress theme with 3D avatar, VR, games, and e-commerce",
  "scripts": {
    "dev": "cd wp-content/themes/youtuneai-theme && npm run dev",
    "build": "cd wp-content/themes/youtuneai-theme && npm run build",
    "test": "cd wp-content/themes/youtuneai-theme && npm test",
    "lint": "cd wp-content/themes/youtuneai-theme && npm run lint",
    "install-theme": "cd wp-content/themes/youtuneai-theme && npm ci"
  },
  "keywords": [
    "wordpress",
    "theme",
    "youtuneai",
    "3d",
    "vr",
    "games",
    "woocommerce"
  ],
  "author": "3000Studios",
  "license": "GPL-2.0-or-later",
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "eslint": "^9.33.0",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.6.2"
  },
  "workspaces": [
    "wp-content/themes/youtuneai-theme"
  ]
}
