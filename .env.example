# YouTuneAI Development Environment
# Copy this to .env and update with your actual values

# WordPress Configuration
WP_DEBUG=true
WP_DEBUG_LOG=true
WP_DEBUG_DISPLAY=false
WP_ENV=development

# Development flags
VITE_DEV=1
NODE_ENV=development

# API Keys (replace with your real keys)
OPENAI_API_KEY=your_openai_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_here
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_SECRET=your_paypal_secret_here
GA_MEASUREMENT_ID=G-XXXXXXXXXX
ADSENSE_PUB_ID=pub-xxxxxxxxxxxxxxxx

# IONOS Hosting Configuration
IONOS_HOST=access-5017098454.webspace-host.com
IONOS_USER=your_ionos_user
IONOS_PASS=your_ionos_password

# Testing Configuration
TEST_BASE_URL=http://localhost:8080
WP_ADMIN_USER=admin
WP_ADMIN_PASS=password

# GitHub Integration
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=3000Studios/YouTuneAi.COM

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password